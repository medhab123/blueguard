{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "frontend-live/dist",
  "installCommand": "npm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/obis",
      "destination": "https://api.obis.org/v3/occurrence"
    },
    {
      "source": "/api/gbif",
      "destination": "https://api.gbif.org/v1/occurrence/search"
    },
    {
      "source": "/api/inat",
      "destination": "https://api.inaturalist.org/v1/observations"
    },
    {
      "source": "/api/openmeteo",
      "destination": "https://marine-api.open-meteo.com/v1/marine"
    },
    {
      "source": "/api/noaa",
      "destination": "https://coastwatch.noaa.gov/erddap/griddap/noaacwN20VIIRSchlaWeekly.csv"
    }
  ]
}
